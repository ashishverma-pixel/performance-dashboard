function fmtR(n){return n>=100000?'₹'+(n/100000).toFixed(2)+'L':'₹'+Math.round(n).toLocaleString('en-IN')}

function gv(key){
  if(cS==='all') return zones().reduce((s,z)=>s+ZD[z][key],0);
  const sd=SD[cS],st=Object.values(sd.zones).reduce((a,b)=>a+b,0);
  const ft=zones().reduce((s,z)=>s+(sd.zones[z]||0),0);
  if(key==='total') return ft;
  if(key==='delivered') return Math.round(ft*(sd.dRate/100));
  if(key==='undeliv') return ft-Math.round(ft*(sd.dRate/100));
  if(key==='edd') return Math.round(zones().reduce((s,z)=>s+ZD[z].edd,0)*(st>0?ft/st:1)*(sd.orders/6723));
  return zones().reduce((s,z)=>s+ZD[z][key],0);
}

