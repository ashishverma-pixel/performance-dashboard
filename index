function doZone(z,el){document.querySelectorAll('#zc .chip').forEach(c=>c.classList.remove('on'));el.classList.add('on');cZ=z;upd();updCharts();}
function doLC(v){cLC=+v;document.getElementById('lv').textContent='₹'+v;upd();updLabor();}
function doReset(){cS='all';cZ='all';cLC=160;document.getElementById('lcs').value=160;document.getElementById('lv').textContent='₹160';document.querySelectorAll('#zc .chip').forEach((c,i)=>c.classList.toggle('on',i===0));document.querySelectorAll('#sc .sender-chip').forEach((c,i)=>c.classList.toggle('on',i===0));upd();updCharts();updLabor();}
function showP(n,el){document.querySelectorAll('.panel').forEach(p=>p.classList.remove('show'));document.querySelectorAll('.tp').forEach(t=>t.classList.remove('on'));document.getElementById('panel-'+n).classList.add('show');if(el) el.classList.add('on');}

function mkCharts(){
  const zl=['Zone A','Zone B','Zone C','Zone D','Zone E'],zk=Object.keys(ZD),zc=['#1D9E75','#5DCAA5','#F5A623','#D85A30','#E24B4A'];
  charts.d=new Chart(document.getElementById('dChart'),{type:'doughnut',data:{labels:['Delivered','In transit','First mile','RTO/Cancel','Not serviceable','Pending'],datasets:[{data:[2460,3097,378,13,106,669],backgroundColor:['#1D9E75','#378ADD','#F5A623','#E24B4A','#64748B','#534AB7'],borderWidth:0,hoverOffset:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},cutout:'72%'}});
  charts.v=new Chart(document.getElementById('vChart'),{type:'bar',data:{labels:zl,datasets:[{data:zk.map(z=>ZD[z].total),backgroundColor:zc,borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}}}});
  charts.s=new Chart(document.getElementById('sChart'),{type:'scatter',data:{datasets:zk.map((z,i)=>({label:zl[i],data:[{x:ZD[z].freight,y:ZD[z].rate}],backgroundColor:zc[i],pointRadius:9,pointHoverRadius:12}))},options:{...BO,plugins:{legend:{display:false}},scales:{x:{...BO.scales.x,title:{display:true,text:'Avg freight (₹)',color:'#64748B',font:{size:9}}},y:{...BO.scales.y,title:{display:true,text:'Delivery %',color:'#64748B',font:{size:9}}}}}});
  charts.e=new Chart(document.getElementById('eChart'),{type:'bar',data:{labels:zl,datasets:[{data:zk.map(z=>ZD[z].edd),backgroundColor:zc,borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}}}});
  charts.t=new Chart(document.getElementById('tChart'),{type:'bar',data:{labels:zl,datasets:[{data:[0.2,1.2,2.7,3.0,3.3],backgroundColor:zc,borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}},scales:{...BO.scales,y:{...BO.scales.y,max:4}}}});
  charts.fz=new Chart(document.getElementById('fzChart'),{type:'bar',data:{labels:zl,datasets:[{data:zk.map(z=>ZD[z].freight),backgroundColor:zc,borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}}}});
  const sn=Object.keys(SD),sc2=sn.map(n=>SD[n].color);
  charts.sv=new Chart(document.getElementById('svChart'),{type:'bar',data:{labels:sn,datasets:[{data:sn.map(n=>SD[n].orders),backgroundColor:sc2,borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}}}});
  charts.sp=new Chart(document.getElementById('spChart'),{type:'bar',data:{labels:sn,datasets:[{data:sn.map(n=>SD[n].pRate),backgroundColor:sn.map(n=>SD[n].pRate>50?'#E24B4A':SD[n].pRate>20?'#F5A623':'#1D9E75'),borderRadius:4}]},options:{...BO,plugins:{legend:{display:false}},scales:{...BO.scales,y:{...BO.scales.y,max:110,ticks:{...TK,callback:v=>v+'%'}}}}});
  const cl=COURIERS.map(c=>c.n),cc=COURIERS.map(c=>c.rate>=70?'#1D9E75':c.rate>=50?'#F5A623':'#E24B4A');
  charts.c=new Chart(document.getElementById('cChart'),{type:'bar',data:{labels:cl,datasets:[{data:COURIERS.map(c=>c.rate),backgroundColor:cc,borderRadius:4}]},options:{...BO,indexAxis:'y',scales:{x:{...BO.scales.x,max:100,ticks:{...TK,callback:v=>v+'%'}},y:{...BO.scales.y,ticks:{color:'#94A3B8',font:{size:9}}}}}});
  charts.ce=new Chart(document.getElementById('ceChart'),{type:'bar',data:{labels:cl,datasets:[{data:COURIERS.map(c=>c.edd),backgroundColor:'#E24B4A',borderRadius:3}]},options:{...BO,indexAxis:'y',scales:{x:{...BO.scales.x},y:{...BO.scales.y,ticks:{color:'#94A3B8',font:{size:8}}}}}});
  charts.cf=new Chart(document.getElementById('cfChart'),{type:'bar',data:{labels:cl,datasets:[{data:COURIERS.map(c=>c.freight),backgroundColor:'#534AB7',borderRadius:3}]},options:{...BO,indexAxis:'y',scales:{x:{...BO.scales.x},y:{...BO.scales.y,ticks:{color:'#94A3B8',font:{size:8}}}}}});
  charts.l=new Chart(document.getElementById('lChart'),{type:'bar',data:{labels:['NDR loop','EDD monitoring','Report downloads','Pin checks','Approval emails'],datasets:[{data:[7200,6000,4174,2000,1000],backgroundColor:['#E24B4A','#D85A30','#F5A623','#BA7517','#64748B'],borderRadius:4}]},options:{...BO,indexAxis:'y',plugins:{legend:{display:false}}}});
  const mo=['M1','M2','M3','M4','M5','M6','M7','M8','M9','M10','M11','M12'];
  charts.cu=new Chart(document.getElementById('cuChart'),{type:'line',data:{labels:mo,datasets:[{label:'Manual labor',data:mo.map((_,i)=>(i+1)*20374),borderColor:'#E24B4A',backgroundColor:'rgba(226,75,74,0.1)',fill:true,tension:.3,pointRadius:3},{label:'Portal total',data:mo.map((_,i)=>500000+(i+1)*4800),borderColor:'#1D9E75',backgroundColor:'rgba(29,158,117,0.08)',fill:true,tension:.3,pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:GR},ticks:TK},y:{grid:{color:GR},ticks:{...TK,callback:v=>'₹'+(v/1000).toFixed(0)+'k'}}}}});
}

function updCharts(){
  const zk=Object.keys(ZD),zl=['Zone A','Zone B','Zone C','Zone D','Zone E'],zc=['#1D9E75','#5DCAA5','#F5A623','#D85A30','#E24B4A'];
  const fi2=cZ==='all'?[0,1,2,3,4]:[zk.indexOf(cZ)];
  const fl=fi2.map(i=>zl[i]),fc=fi2.map(i=>zc[i]),fz=fi2.map(i=>zk[i]);
  const gval=(z,key)=>{if(cS==='all') return ZD[z][key];const sd=SD[cS],sz=sd.zones[z]||0;if(key==='total') return sz;if(key==='edd') return Math.round(ZD[z].edd*(sz/ZD[z].total));return ZD[z][key];};
  ['v','e'].forEach(k=>{if(!charts[k]) return;charts[k].data.labels=fl;charts[k].data.datasets[0].data=fz.map(z=>gval(z,k==='e'?'edd':'total'));charts[k].data.datasets[0].backgroundColor=fc;charts[k].update();});
  ['t','fz'].forEach(k=>{if(!charts[k]) return;charts[k].data.labels=fl;charts[k].data.datasets[0].data=fz.map(z=>k==='t'?ZD[z].tat:ZD[z].freight);charts[k].data.datasets[0].backgroundColor=fc;charts[k].update();});
  if(charts.sv){const bgs=Object.keys(SD).map(n=>cS==='all'?SD[n].color:n===cS?SD[n].color:'#1E3A52');charts.sv.data.datasets[0].backgroundColor=bgs;charts.sv.update();}
}

function updLabor(){const sc=cLC/160;if(charts.l){charts.l.data.datasets[0].data=[7200,6000,4174,2000,1000].map(v=>Math.round(v*sc));charts.l.update();}if(charts.cu){charts.cu.data.datasets[0].data=Array.from({length:12},(_,i)=>Math.round((i+1)*20374*sc));charts.cu.update();}}

mkCharts();upd();
</script>
</body>
</html>
