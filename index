<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Influencer Dispatch Ops — Analytics Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0;font-family:'Inter',system-ui,sans-serif}
:root{
  --navy:#0D1B2A;--teal:#00A896;--red:#E24B4A;--amber:#F5A623;--green:#1D9E75;
  --purple:#7F77DD;--card:#132638;--border:#1E3A52;--muted:#64748B;--light:#CBD5E1;
  --bg:#0A1628;--sidebar:#0F2236;
}
html,body{height:100%;background:var(--bg)}
.dash{background:var(--bg);min-height:100vh;display:grid;grid-template-columns:240px 1fr;grid-template-rows:52px 1fr}
.topbar{grid-column:1/-1;background:var(--navy);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px}
.topbar-title{font-size:14px;font-weight:600;color:#fff;letter-spacing:.3px}
.topbar-sub{font-size:11px;color:var(--muted);margin-top:1px}
.topbar-right{display:flex;align-items:center;gap:12px}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.live-txt{font-size:11px;color:var(--green);font-weight:500}
.last-upd{font-size:11px;color:var(--muted)}
.logo-pill{background:rgba(0,168,150,.15);border:1px solid rgba(0,168,150,.3);color:var(--teal);font-size:10px;font-weight:600;padding:3px 10px;border-radius:20px;letter-spacing:.05em}
.sidebar{background:var(--sidebar);border-right:1px solid var(--border);padding:14px 12px;overflow-y:auto}
.slicer-title{font-size:10px;font-weight:600;color:var(--teal);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid var(--border)}
.slicer-section{margin-bottom:18px}
.chip-group{display:flex;flex-wrap:wrap;gap:4px}
.chip{padding:4px 9px;border-radius:20px;font-size:10px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--light);background:transparent;transition:all .15s}
.chip:hover{border-color:var(--teal);color:var(--teal)}
.chip.on{background:var(--teal);color:#fff;border-color:var(--teal)}
.sender-chip{padding:4px 9px;border-radius:20px;font-size:10px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--light);background:transparent;transition:all .15s;display:flex;align-items:center;gap:5px}
.sender-chip:hover{border-color:var(--purple);color:#fff}
.sender-chip.on{background:var(--purple);color:#fff;border-color:var(--purple)}
.s-av{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;flex-shrink:0;color:#fff}
.slicer-label{font-size:11px;color:var(--light);margin-bottom:5px}
.range-wrap{padding:0 4px}
.range-wrap input[type=range]{width:100%;accent-color:var(--teal);cursor:pointer}
.range-vals{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-top:3px}
.mm{background:var(--card);border:1px solid var(--border);border-radius:6px;padding:8px 10px;margin-bottom:6px;cursor:pointer;transition:border-color .15s}
.mm:hover{border-color:var(--teal)}
.mm .mv{font-size:17px;font-weight:700;color:#fff}
.mm .ml{font-size:9px;color:var(--muted);margin-top:1px;text-transform:uppercase;letter-spacing:.04em}
.mm .mt{font-size:9px;margin-top:2px}
.mm.red .mv{color:var(--red)}.mm.amber .mv{color:var(--amber)}.mm.green .mv{color:var(--green)}
.main{padding:14px;overflow-y:auto}
.kpi-row{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;margin-bottom:14px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px 14px;position:relative;overflow:hidden;transition:border-color .15s}
.kpi:hover{border-color:var(--teal)}
.kpi-ac{position:absolute;top:0;left:0;width:100%;height:3px}
.kpi-val{font-size:22px;font-weight:700;color:#fff;margin-top:6px;line-height:1}
.kpi-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
.kpi-d{font-size:10px;margin-top:6px}
.cr{display:grid;grid-template-columns:1.4fr 1fr;gap:12px;margin-bottom:12px}
.cr2{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
.cc{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:14px;transition:border-color .15s}
.cc:hover{border-color:rgba(0,168,150,.3)}
.ct{font-size:11px;font-weight:600;color:#fff;margin-bottom:2px}
.cs{font-size:9px;color:var(--muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em}
.cw{position:relative;width:100%}
.zbr{margin-bottom:7px}
.zbl{display:flex;justify-content:space-between;font-size:10px;color:var(--light);margin-bottom:3px}
.zt{background:#1E3A52;border-radius:3px;height:20px;overflow:hidden}
.zf{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:8px;font-size:9px;font-weight:600;color:#fff;transition:width .6s ease}
.rr{display:flex;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:11px;gap:8px}
.rr:last-child{border-bottom:none}
.rb{padding:2px 7px;border-radius:3px;font-size:9px;font-weight:600;flex-shrink:0}
.rb.h{background:rgba(226,75,74,.2);color:var(--red)}
.rb.m{background:rgba(245,166,35,.2);color:var(--amber)}
.rb.l{background:rgba(29,158,117,.2);color:var(--green)}
.dw{display:flex;align-items:center;gap:16px}
.dl{flex:1}
.dlr{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--light);margin-bottom:6px}
.dld{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.reset-btn{width:100%;padding:7px;border-radius:6px;background:transparent;border:1px solid var(--border);color:var(--muted);font-size:10px;cursor:pointer;margin-top:8px;transition:all .15s;font-family:inherit}
.reset-btn:hover{border-color:var(--teal);color:var(--teal)}
.ftag{display:inline-flex;align-items:center;gap:4px;border:1px solid;padding:2px 8px;border-radius:12px;font-size:10px;margin:2px}
.ftag.zone{background:rgba(0,168,150,.1);color:var(--teal);border-color:rgba(0,168,150,.3)}
.ftag.sender{background:rgba(127,119,221,.1);color:var(--purple);border-color:rgba(127,119,221,.3)}
.fbar{min-height:24px;margin-bottom:10px;display:flex;flex-wrap:wrap;align-items:center;gap:2px}
.fbar-lbl{font-size:10px;color:var(--muted);margin-right:4px}
.tabs{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.tp{padding:5px 14px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--muted);background:transparent;transition:all .15s;font-family:inherit}
.tp:hover{border-color:var(--teal);color:var(--teal)}
.tp.on{background:var(--teal);color:#fff;border-color:var(--teal)}
.panel{display:none}.panel.show{display:block}
.stbl{width:100%;border-collapse:collapse;font-size:11px}
.stbl th{text-align:left;font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding:6px 8px;border-bottom:1px solid var(--border);letter-spacing:.04em}
.stbl td{padding:7px 8px;border-bottom:1px solid var(--border);color:var(--light);vertical-align:middle}
.stbl tr:last-child td{border-bottom:none}
.stbl tr:hover td{background:rgba(0,168,150,.05)}
.sbmini{height:5px;border-radius:3px;background:#1E3A52;overflow:hidden;margin-top:3px}
.sbfill{height:100%;border-radius:3px}
.tl{display:grid;grid-template-columns:repeat(5,1fr);margin-top:12px}
.tlc{text-align:center;padding:10px 4px;border-right:1px solid #1E3A52}
.tlc:last-child{border-right:none}
.tld{width:14px;height:14px;border-radius:50%;margin:0 auto 6px}
.ib{border-radius:6px;padding:10px 14px;margin-top:12px;font-size:11px;line-height:1.6}
</style>
</head>
<body>
<div class="dash">

<div class="topbar">
  <div>
    <div class="topbar-title">Influencer Dispatch Operations — Analytics Dashboard</div>
    <div class="topbar-sub" id="tb-ctx">Delhi WH · PAN India · March 2026 · All senders · All zones</div>
  </div>
  <div class="topbar-right">
    <div class="live-dot"></div><span class="live-txt">Live</span>
    <span class="last-upd">Last updated: 11 Mar 2026</span>
    <span class="logo-pill">SC OPS</span>
  </div>
</div>

<div class="sidebar">

  <div class="slicer-section">
    <div class="slicer-title">Sender person</div>
    <div class="chip-group" id="sc">
      <div class="sender-chip on" onclick="doSender('all',this)"><span class="s-av" style="background:#1E3A52">A</span>All</div>
      <div class="sender-chip" onclick="doSender('Shalini',this)"><span class="s-av" style="background:#1D9E75">SH</span>Shalini</div>
      <div class="sender-chip" onclick="doSender('Simar',this)"><span class="s-av" style="background:#378ADD">SI</span>Simar</div>
      <div class="sender-chip" onclick="doSender('Shreya',this)"><span class="s-av" style="background:#F5A623">SR</span>Shreya</div>
      <div class="sender-chip" onclick="doSender('Muskan',this)"><span class="s-av" style="background:#E24B4A">MU</span>Muskan</div>
      <div class="sender-chip" onclick="doSender('Rhytham',this)"><span class="s-av" style="background:#534AB7">RH</span>Rhytham</div>
      <div class="sender-chip" onclick="doSender('Agrima',this)"><span class="s-av" style="background:#00A896">AG</span>Agrima</div>
      <div class="sender-chip" onclick="doSender('Rakhi Singh',this)"><span class="s-av" style="background:#D85A30">RK</span>Rakhi Singh</div>
      <div class="sender-chip" onclick="doSender('Sanya',this)"><span class="s-av" style="background:#639922">SA</span>Sanya</div>
    </div>
  </div>

  <div class="slicer-section">
    <div class="slicer-title">Zone slicer</div>
    <div class="chip-group" id="zc">
      <div class="chip on" onclick="doZone('all',this)">All zones</div>
      <div class="chip" onclick="doZone('z_a',this)">Zone A</div>
      <div class="chip" onclick="doZone('z_b',this)">Zone B</div>
      <div class="chip" onclick="doZone('z_c',this)">Zone C</div>
      <div class="chip" onclick="doZone('z_d',this)">Zone D</div>
      <div class="chip" onclick="doZone('z_e',this)">Zone E</div>
    </div>
  </div>

  <div class="slicer-section">
    <div class="slicer-title">TAT threshold (days)</div>
    <div class="slicer-label">Max acceptable: <strong id="tv" style="color:var(--teal)">3</strong> days</div>
    <div class="range-wrap">
      <input type="range" min="1" max="5" step="1" value="3" oninput="document.getElementById('tv').textContent=this.value">
      <div class="range-vals"><span>1d</span><span>3d</span><span>5d</span></div>
    </div>
  </div>

  <div class="slicer-section">
    <div class="slicer-title">Labor cost / hr (₹)</div>
    <div class="slicer-label">Rate: <strong id="lv" style="color:var(--amber)">₹160</strong></div>
    <div class="range-wrap">
      <input type="range" min="80" max="300" step="10" value="160" id="lcs" oninput="doLC(this.value)">
      <div class="range-vals"><span>₹80</span><span>₹190</span><span>₹300</span></div>
    </div>
  </div>

  <div class="slicer-section">
    <div class="slicer-title">Quick KPIs</div>
    <div class="mm red"><div class="mv" id="sb1">3,789</div><div class="ml">Campaign risk orders</div><div class="mt" style="color:var(--red)">Non-ZA undelivered</div></div>
    <div class="mm amber"><div class="mv" id="sb2">₹20,374</div><div class="ml">Monthly labor cost</div><div class="mt" style="color:var(--amber)">Manual ops spend</div></div>
    <div class="mm green"><div class="mv" id="sb3">₹15,574</div><div class="ml">Automation saving</div><div class="mt" style="color:var(--green)">vs ₹4,800 Make.com</div></div>
    <button class="reset-btn" onclick="doReset()">↺ Reset all filters</button>
  </div>

</div>

<div class="main">
  <div class="fbar" id="fb"></div>
  <div class="tabs">
    <div class="tp on" onclick="showP('overview',this)">Overview</div>
    <div class="tp" onclick="showP('sender',this)">Sender analysis</div>
    <div class="tp" onclick="showP('zone',this)">Zone analysis</div>
    <div class="tp" onclick="showP('courier',this)">Courier performance</div>
    <div class="tp" onclick="showP('labor',this)">Labor cost</div>
    <div class="tp" onclick="showP('risk',this)">Risk register</div>
  </div>

  <!-- OVERVIEW -->
  <div id="panel-overview" class="panel show">
    <div class="kpi-row">
      <div class="kpi"><div class="kpi-ac" style="background:var(--teal)"></div><div class="kpi-lbl">Total orders</div><div class="kpi-val" id="k-tot">6,723</div><div class="kpi-d" style="color:var(--teal)" id="k-tot-c">All senders</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--green)"></div><div class="kpi-lbl">Delivered</div><div class="kpi-val" style="color:var(--green)" id="k-del">2,460</div><div class="kpi-d" style="color:var(--muted)" id="k-del-p">36.6%</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--red)"></div><div class="kpi-lbl">EDD breached</div><div class="kpi-val" style="color:var(--red)" id="k-edd">1,629</div><div class="kpi-d" style="color:var(--red)" id="k-edd-p">24.4%</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--amber)"></div><div class="kpi-lbl">Freight spend</div><div class="kpi-val" style="color:var(--amber)" id="k-fr">₹2.34L</div><div class="kpi-d" style="color:var(--muted)" id="k-fr-a">₹35 avg</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--purple)"></div><div class="kpi-lbl">Process pending</div><div class="kpi-val" style="color:var(--purple)" id="k-pend">943</div><div class="kpi-d" style="color:var(--purple)" id="k-pend-p">14.0%</div></div>
    </div>
    <div class="cr">
      <div class="cc">
        <div class="ct">Order status breakdown</div><div class="cs" id="dc-ctx">All senders · all zones</div>
        <div class="dw">
          <div style="position:relative;width:130px;height:130px;flex-shrink:0"><canvas id="dChart"></canvas></div>
          <div class="dl">
            <div class="dlr"><span class="dld" style="background:#1D9E75"></span><span id="dl1">Delivered — 2,460 (36.6%)</span></div>
            <div class="dlr"><span class="dld" style="background:#378ADD"></span>In transit — 3,097 (46.1%)</div>
            <div class="dlr"><span class="dld" style="background:#F5A623"></span>First mile — 378 (5.6%)</div>
            <div class="dlr"><span class="dld" style="background:#E24B4A"></span>RTO/cancel — 13 (0.2%)</div>
            <div class="dlr"><span class="dld" style="background:#64748B"></span>Not serviceable — 106</div>
            <div class="dlr"><span class="dld" style="background:#534AB7"></span><span id="dl6">Pending — 669 (9.9%)</span></div>
          </div>
        </div>
      </div>
      <div class="cc">
        <div class="ct">Delivery rate by zone</div><div class="cs">% delivered · Delhi WH</div>
        <div class="zbr"><div class="zbl"><span>Zone A — NCR</span><span style="color:#1D9E75" id="zr-a">64.6%</span></div><div class="zt"><div class="zf" id="zf-a" style="width:64.6%;background:#1D9E75">64.6%</div></div></div>
        <div class="zbr"><div class="zbl"><span>Zone B — North</span><span style="color:#5DCAA5" id="zr-b">35.1%</span></div><div class="zt"><div class="zf" id="zf-b" style="width:35.1%;background:#5DCAA5">35.1%</div></div></div>
        <div class="zbr"><div class="zbl"><span>Zone C — West</span><span style="color:#F5A623" id="zr-c">31.8%</span></div><div class="zt"><div class="zf" id="zf-c" style="width:31.8%;background:#F5A623">31.8%</div></div></div>
        <div class="zbr"><div class="zbl"><span>Zone D — East</span><span style="color:#D85A30" id="zr-d">30.5%</span></div><div class="zt"><div class="zf" id="zf-d" style="width:30.5%;background:#D85A30">30.5%</div></div></div>
        <div class="zbr"><div class="zbl"><span>Zone E — Far NE/South</span><span style="color:#E24B4A" id="zr-e">27.4%</span></div><div class="zt"><div class="zf" id="zf-e" style="width:27.4%;background:#E24B4A">27.4%</div></div></div>
      </div>
    </div>
    <div class="cr2">
      <div class="cc"><div class="ct">Orders by zone</div><div class="cs">Volume distribution</div><div class="cw" style="height:180px"><canvas id="vChart"></canvas></div></div>
      <div class="cc"><div class="ct">Freight vs delivery rate</div><div class="cs">Efficiency scatter by zone</div><div class="cw" style="height:180px"><canvas id="sChart"></canvas></div></div>
      <div class="cc"><div class="ct">EDD breach by zone</div><div class="cs">Breach count this month</div><div class="cw" style="height:180px"><canvas id="eChart"></canvas></div></div>
    </div>
  </div>

  <!-- SENDER ANALYSIS -->
  <div id="panel-sender" class="panel">
    <div class="kpi-row" style="grid-template-columns:repeat(4,minmax(0,1fr))">
      <div class="kpi"><div class="kpi-ac" style="background:var(--purple)"></div><div class="kpi-lbl">Active senders</div><div class="kpi-val" style="color:var(--purple)">9</div><div class="kpi-d" style="color:var(--muted)">≥10 orders/month</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--teal)"></div><div class="kpi-lbl">Top sender</div><div class="kpi-val" style="color:var(--teal)">Shalini</div><div class="kpi-d" style="color:var(--muted)">3,847 orders · 57.2%</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--red)"></div><div class="kpi-lbl">Highest pending %</div><div class="kpi-val" style="color:var(--red)">Simar</div><div class="kpi-d" style="color:var(--red)">34.9% pending rate</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--amber)"></div><div class="kpi-lbl">Selected sender</div><div class="kpi-val" style="color:var(--amber);font-size:16px" id="k-sel">All senders</div><div class="kpi-d" style="color:var(--muted)" id="k-sel-o">6,723 orders</div></div>
    </div>
    <div class="cr">
      <div class="cc"><div class="ct">Orders per sender</div><div class="cs">Total orders this month</div><div class="cw" style="height:260px"><canvas id="svChart"></canvas></div></div>
      <div class="cc"><div class="ct">Pending rate per sender</div><div class="cs">% still process-pending</div><div class="cw" style="height:260px"><canvas id="spChart"></canvas></div></div>
    </div>
    <div class="cc">
      <div class="ct">Sender-wise order detail</div>
      <div class="cs">Click a sender chip on the left to filter all dashboards</div>
      <table class="stbl"><thead><tr><th>Sender</th><th>Orders</th><th>Processed</th><th>Pending</th><th>Pending %</th><th>Delivery rate</th><th>Avg freight</th><th>Zone spread</th></tr></thead>
      <tbody id="stbody"></tbody></table>
    </div>
  </div>

  <!-- ZONE ANALYSIS -->
  <div id="panel-zone" class="panel">
    <div class="kpi-row" style="grid-template-columns:repeat(4,minmax(0,1fr))">
      <div class="kpi"><div class="kpi-ac" style="background:var(--green)"></div><div class="kpi-lbl">Zone A avg TAT</div><div class="kpi-val" style="color:var(--green)">0.2d</div><div class="kpi-d" style="color:var(--green)">Same-day delivery</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--red)"></div><div class="kpi-lbl">Zone E avg TAT</div><div class="kpi-val" style="color:var(--red)">3.3d</div><div class="kpi-d" style="color:var(--red)">+3.1 days vs Zone A</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--amber)"></div><div class="kpi-lbl">Non-ZA at risk</div><div class="kpi-val" style="color:var(--amber)" id="k-nza">3,789</div><div class="kpi-d" style="color:var(--amber)">65–73% undelivered</div></div>
      <div class="kpi"><div class="kpi-ac" style="background:var(--red)"></div><div class="kpi-lbl">Max campaign delay</div><div class="kpi-val" style="color:var(--red)">3.1d</div><div class="kpi-d" style="color:var(--red)">Zone E vs Zone A</div></div>
    </div>
    <div class="cr">
      <div class="cc"><div class="ct">Avg TAT — Zone A baseline vs others</div><div class="cs">Delivery days from Delhi WH</div><div class="cw" style="height:260px"><canvas id="tChart"></canvas></div></div>
      <div class="cc"><div class="ct">Freight cost by zone</div><div class="cs">Avg ₹ per order</div><div class="cw" style="height:260px"><canvas id="fzChart"></canvas></div></div>
    </div>
    <div class="cc">
      <div class="ct">Campaign window impact — same brief, different go-live</div>
      <div class="cs">Zone A posts on time · Zone E posts 3.1 days late</div>
